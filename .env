PORT=5001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://speaxa_user:YOUR_PASSWORD@localhost:5432/speaxa

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_256BIT_STRING_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_DIFFERENT_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# Agora
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE
AGORA_CUSTOMER_KEY=YOUR_AGORA_CUSTOMER_KEY
AGORA_CUSTOMER_SECRET=YOUR_AGORA_CUSTOMER_SECRET

# AWS S3 / Cloudflare R2
S3_BUCKET=speaxa-files
S3_REGION=ap-south-1
S3_ACCESS_KEY=YOUR_ACCESS_KEY
S3_SECRET_KEY=YOUR_SECRET_KEY
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
CDN_BASE_URL=https://cdn.speaxa.com

# Firebase FCM
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Email (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=YOUR_SENDGRID_API_KEY
EMAIL_FROM=noreply@speaxa.com

# MSG91 (OTP SMS)
MSG91_AUTH_KEY=YOUR_MSG91_AUTH_KEY
MSG91_SENDER_ID=SPXSA
MSG91_TEMPLATE_ID=YOUR_TEMPLATE_ID

# Admin
ADMIN_EMAIL=admin@speaxa.com
ADMIN_PASSWORD=ChangeThisSecurePassword123
